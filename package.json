{
  "name": "roundfi",
  "version": "0.1.0",
  "private": true,
  "description": "RoundFi — cooperative on-chain credit protocol on Solana",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alrimarleskovar/RoundFinancial.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:keys": "anchor keys sync",
    "anchor:clean": "anchor clean",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p .",
    "docs:build-pdfs": "bash scripts/docs/build-pdfs.sh",
    "devnet:airdrop": "tsx scripts/devnet/airdrop.ts",
    "devnet:deploy": "tsx scripts/devnet/deploy.ts",
    "devnet:export-pk": "tsx scripts/devnet/export-pk.ts",
    "devnet:init": "tsx scripts/devnet/init-protocol.ts",
    "devnet:migrate-config": "tsx scripts/devnet/migrate-config.ts",
    "devnet:update-config": "tsx scripts/devnet/update-config.ts",
    "devnet:migrate-reputation-config": "tsx scripts/devnet/migrate-reputation-config.ts",
    "devnet:set-identity-gate": "tsx scripts/devnet/set-identity-gate.ts",
    "devnet:seed": "tsx scripts/devnet/seed-pool.ts",
    "devnet:fund-members": "tsx scripts/devnet/fund-members.ts",
    "devnet:seed-members": "tsx scripts/devnet/seed-members.ts",
    "devnet:seed-cycle": "tsx scripts/devnet/seed-cycle.ts",
    "devnet:seed-claim": "tsx scripts/devnet/seed-claim.ts",
    "devnet:seed-topup": "tsx scripts/devnet/seed-topup.ts",
    "devnet:seed-release": "tsx scripts/devnet/seed-release.ts",
    "devnet:seed-yield-init": "tsx scripts/devnet/seed-yield-init.ts",
    "devnet:seed-yield-deposit": "tsx scripts/devnet/seed-yield-deposit.ts",
    "devnet:seed-yield-harvest": "tsx scripts/devnet/seed-yield-harvest.ts",
    "devnet:seed-evlist": "tsx scripts/devnet/seed-evlist.ts",
    "devnet:seed-evlist-commit": "tsx scripts/devnet/seed-evlist-commit.ts",
    "devnet:seed-evbuy": "tsx scripts/devnet/seed-evbuy.ts",
    "devnet:seed-close": "tsx scripts/devnet/seed-close.ts",
    "devnet:seed-close-vaults": "tsx scripts/devnet/seed-close-vaults.ts",
    "devnet:seed-default": "tsx scripts/devnet/seed-default.ts",
    "devnet:pause-rehearsal": "tsx scripts/devnet/pause-rehearsal.ts",
    "devnet:unpause": "tsx scripts/devnet/unpause.ts",
    "devnet:squads-derive-pda": "tsx scripts/devnet/squads-derive-pda.ts",
    "devnet:squads-rehearsal-verify": "tsx scripts/devnet/squads-rehearsal-verify.ts",
    "devnet:squads-rehearsal-propose": "tsx scripts/devnet/squads-rehearsal-propose-authority.ts",
    "devnet:squads-rehearsal-cancel": "tsx scripts/devnet/squads-rehearsal-cancel-authority.ts",
    "devnet:squads-rehearsal-commit": "tsx scripts/devnet/squads-rehearsal-commit-authority.ts",
    "devnet:verify-build": "bash scripts/devnet/verify-build.sh",
    "devnet:verify-check": "bash scripts/devnet/verify-check.sh",
    "devnet:verify-redeploy": "bash scripts/devnet/verify-redeploy.sh",
    "devnet:verify-onchain": "bash scripts/devnet/verify-onchain.sh",
    "test:parity": "pnpm exec mocha -t 60000 'tests/parity.spec.ts'",
    "test:frontend-allowlist": "pnpm exec mocha -t 60000 'tests/frontend_allowlist.spec.ts'",
    "test:tx-simulation": "pnpm exec mocha -t 60000 'tests/tx_simulation.spec.ts'",
    "test:indexer-log": "pnpm exec mocha -t 60000 'tests/indexer_log.spec.ts'",
    "test:indexer-webhook-auth": "pnpm exec mocha -t 60000 'services/indexer/test/webhook-auth.spec.ts'",
    "test:rpc-quorum": "pnpm exec mocha -t 60000 'tests/rpc_quorum.spec.ts'",
    "test:admin-rate-limit": "pnpm exec mocha -t 60000 'tests/admin_rate_limit.spec.ts'",
    "test:admin-authority-cache": "pnpm exec mocha -t 60000 'tests/admin_authority_cache.spec.ts'",
    "test:admin-auth": "pnpm exec mocha -t 60000 'tests/admin_auth.spec.ts'",
    "test:admin-shared-store": "pnpm exec mocha -t 60000 'tests/admin_shared_store.spec.ts'",
    "test:email-optin": "pnpm exec mocha -t 60000 'tests/email_optin.spec.ts'",
    "test:email-send": "pnpm exec mocha -t 60000 'tests/email_send.spec.ts'",
    "test:yield-harvest-floor": "pnpm exec mocha -t 60000 'tests/yield_harvest_floor.spec.ts'",
    "test:kamino-pin": "pnpm exec mocha -t 60000 'tests/kamino_pin_verify.spec.ts'",
    "verify:kamino-pin": "tsx scripts/mainnet/verify-kamino-pin.ts",
    "test:app-encoders": "pnpm exec mocha -t 60000 'tests/app_encoders.spec.ts'",
    "test:events": "pnpm exec mocha -t 60000 'tests/events.spec.ts'",
    "test:behavioral-payload": "pnpm exec mocha -t 60000 'tests/behavioral_payload_parity.spec.ts'",
    "test:attestation-decode": "pnpm exec mocha -t 60000 'tests/onchain_raw_attestation.spec.ts'",
    "test:behavioral-classification": "pnpm exec mocha -t 60000 'services/indexer/test/behavioral_classification.spec.ts'",
    "test:attestation-row": "pnpm exec mocha -t 60000 'services/indexer/test/attestation_row.spec.ts'",
    "test:reputation-metrics": "pnpm exec mocha -t 60000 'services/indexer/test/reputation_metrics.spec.ts'",
    "test:reputation-score": "pnpm exec mocha -t 60000 'services/indexer/test/reputation_score.spec.ts'",
    "test:score-route": "pnpm exec mocha -t 60000 'services/indexer/test/score_route.spec.ts'",
    "test:infer-default-reason": "pnpm exec mocha -t 60000 'services/indexer/test/infer_default_reason.spec.ts'",
    "test:economic-parity-l1": "pnpm exec mocha -t 60000 -g 'L1 stress-lab sanity|toggleCell|runSimulation' 'tests/economic_parity.spec.ts'",
    "test:economic-parity": "pnpm exec mocha -t 120000 'tests/economic_parity.spec.ts'",
    "test:bankrun": "pnpm exec mocha -t 120000 'tests/economic_parity.spec.ts' 'tests/lifecycle.spec.ts' 'tests/edge_*.spec.ts' 'tests/app_encoders_bankrun.spec.ts' 'tests/security_kamino_cpi.spec.ts'",
    "test:bankrun:no-mpl-core": "pnpm exec mocha -t 120000 'tests/security_kamino_cpi.spec.ts'",
    "test:bankrun:reputation-gate": "pnpm exec mocha -t 120000 'tests/reputation_gate_bankrun.spec.ts'",
    "test:bankrun:identity-floor": "pnpm exec mocha -t 180000 'tests/reputation_identity_floor_bankrun.spec.ts'",
    "test:litesvm": "pnpm exec mocha -t 120000 'tests/litesvm_*.spec.ts'",
    "test:security:localnet": "pnpm exec mocha -t 120000 'tests/security_*.spec.ts'",
    "test:fuzz": "for t in bps cascade dc_invariant escrow_vesting seed_draw waterfall; do echo \"=== fuzz target: $t ===\"; cargo fuzz run --fuzz-dir crates/math/fuzz \"$t\" -- -max_total_time=60 || exit 1; done",
    "test:mainnet-hardening": "tsx scripts/mainnet/mainnet-hardening-check.ts",
    "test:reconciler-lease": "pnpm exec mocha -t 60000 'services/indexer/test/reconciler-lease.spec.ts'",
    "mainnet:deploy": "tsx scripts/mainnet/deploy.ts"
  },
  "devDependencies": {
    "@roundfi/sdk": "workspace:*",
    "@types/chai": "^4.3.17",
    "@types/mocha": "^10.0.7",
    "@types/node": "^25.9.1",
    "anchor-bankrun": "^0.5.0",
    "chai": "^6.2.2",
    "mocha": "^10.7.3",
    "prettier": "^3.8.4",
    "solana-bankrun": "^0.4.0",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@metaplex-foundation/mpl-core": "^1.1.1",
    "@metaplex-foundation/umi": "^1.5.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/transactions": "6.9.0",
    "@solana/web3.js": "^1.95.3",
    "dotenv": "^16.4.5",
    "litesvm": "^1.1.0"
  },
  "pnpm": {
    "overrides": {
      "shell-quote@<1.8.4": ">=1.8.4"
    }
  }
}
