# React Native requires a flat node_modules. Metro's resolver does not
# traverse pnpm's isolated symlink farm reliably (deep RN transitive
# deps like @babel/runtime, fast-base64-decode go unresolved). Since
# mobile/ is a standalone project (NOT a pnpm workspace member — see
# ../pnpm-workspace.yaml), node-linker=hoisted here is local and does
# NOT affect app/services/sdk in the main workspace.
node-linker=hoisted
