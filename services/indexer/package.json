{
  "name": "@roundfi/indexer",
  "version": "0.1.0",
  "private": true,
  "description": "RoundFi indexer — Helius webhook subscriber + on-chain backfiller. Hydrates a Postgres event store from Pool / Member / Attestation accounts and contribute / claim_payout / settle_default txs. Phase 3 (B2B oracle) reads from this DB.",
  "license": "Apache-2.0",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "main": "./src/server.ts",
  "exports": {
    ".": "./src/server.ts",
    "./db": "./src/db.ts",
    "./admin": "./src/adminQueries.ts",
    "./insights": "./src/insights.ts",
    "./reputation-score": "./src/reputationScore.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "backfill": "tsx src/backfill.ts",
    "backfill:events": "tsx src/backfill-events.ts",
    "reconcile": "tsx src/reconciler.ts",
    "reconcile:once": "tsx src/reconciler.ts --once",
    "notify": "tsx src/email/notify.ts",
    "notify:once": "tsx src/email/notify.ts --once",
    "project-events": "tsx src/projector.ts",
    "seed:insights": "tsx src/seed-insights.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@roundfi/sdk": "workspace:*",
    "@solana/web3.js": "^1.95.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.9.0",
    "nodemailer": "^6.9.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^6.4.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
