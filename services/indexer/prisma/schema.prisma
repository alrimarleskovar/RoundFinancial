// RoundFi indexer event store.
//
// Mirrors the on-chain account / event surface 1:1 so the B2B oracle
// (Phase 3) can answer score / reputation queries without a fresh
// `getProgramAccounts` round-trip every time. Source of truth is still
// on-chain; this DB is a read-replica fed by Helius webhooks +
// periodic backfill.
//
// Naming convention: lowercase_snake table names + camelCase columns
// to keep the API layer's JSON output ergonomic without
// per-field aliases. Pubkeys land as base58 strings (44 chars) for
// portability — they're indexed but not used in joins (FK is
// id → id, not pubkey → pubkey).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Pools ───────────────────────────────────────────────────────────

model Pool {
  id                      String            @id @default(cuid())
  /// PDA address — the canonical identity, indexed for lookup
  pda                     String            @unique
  /// (authority, seedId) tuple — used to re-derive the PDA off-chain
  authority               String
  seedId                  BigInt
  /// Snapshot of pool config at the time of last update
  usdcMint                String
  yieldAdapter            String
  membersTarget           Int
  installmentAmount       BigInt
  creditAmount            BigInt
  cyclesTotal             Int
  cycleDurationSec        BigInt
  seedDrawBps             Int
  solidarityBps           Int
  escrowReleaseBps        Int
  /// Mutable state (refreshed every event)
  membersJoined           Int
  status                  PoolStatus
  startedAt               BigInt?
  currentCycle            Int
  nextCycleAt             BigInt?
  totalContributed        BigInt
  totalPaidOut            BigInt
  solidarityBalance       BigInt
  escrowBalance           BigInt
  yieldAccrued            BigInt
  guaranteeFundBalance    BigInt
  totalProtocolFeeAccrued BigInt
  yieldPrincipalDeposited BigInt
  defaultedMembers        Int
  /// Slot bitmap — packed [u8; 8], stored as base16 hex for portability
  slotsBitmapHex          String
  /// Audit trail
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  /// Reverse relations
  members                 Member[]
  contributeEvents        ContributeEvent[]
  claimEvents             ClaimEvent[]
  defaultEvents           DefaultEvent[]

  @@index([authority])
  @@map("pools")
}

enum PoolStatus {
  Forming
  Active
  Completed
  Liquidated
  Closed
}

// ─── Members ─────────────────────────────────────────────────────────

model Member {
  id                     String            @id @default(cuid())
  /// PDA address (= [b"member", pool, wallet] under core program)
  pda                    String            @unique
  pool                   Pool              @relation(fields: [poolId], references: [id])
  poolId                 String
  /// The wallet that joined (= subject of attestations)
  wallet                 String
  nftAsset               String
  slotIndex              Int
  reputationLevel        Int
  stakeBps               Int
  stakeDeposited         BigInt
  contributionsPaid      Int
  totalContributed       BigInt
  totalReceived          BigInt
  escrowBalance          BigInt
  onTimeCount            Int
  lateCount              Int
  defaulted              Boolean
  paidOut                Boolean
  lastReleasedCheckpoint Int
  joinedAt               BigInt
  /// Step 4c invariants — initials never mutated
  stakeDepositedInitial  BigInt
  totalEscrowDeposited   BigInt
  lastTransferredAt      BigInt
  /// Audit trail
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  /// Reverse relations
  attestations           Attestation[]
  contributeEvents       ContributeEvent[]
  claimEvents            ClaimEvent[]

  @@unique([poolId, slotIndex])
  @@index([wallet])
  @@map("members")
}

// ─── Attestations (SAS-compatible) ───────────────────────────────────

model Attestation {
  id          String   @id @default(cuid())
  /// PDA address (= [b"attestation", issuer, subject, schemaId, nonce])
  pda         String   @unique
  /// Issuer = pool PDA. Subject = wallet (member's identity).
  issuer      String
  subject     String
  schemaId    Int
  /// nonce = (cycle << 32) | slotIndex
  nonce       BigInt
  /// Optional FK back to Member (when issuer is a known pool +
  /// subject is a member of that pool). NULL for orphan attestations.
  member      Member?  @relation(fields: [memberId], references: [id])
  memberId    String?
  /// Raw 96-byte payload as a lowercase hex string (192 chars). Kept for
  /// the audit trail / byte-level diffing; structured fields below are
  /// the decoded view. NULL only for rows ingested before v5.2 wrote it.
  payload     String?

  // ─── v5.2 Hybrid BehavioralPayload (Phase C.2b) ────────────────────
  // Decoded off-chain via @roundfi/sdk decodeAttestationRaw +
  // deriveEventClassification. `payloadVersion` NULL = legacy zero
  // payload (pre-v5.2) — all structured fields below are then NULL and
  // `classification` is "unspecified".
  /// BehavioralPayload version (1 for v5.2); NULL = legacy zero payload.
  payloadVersion Int?
  /// Authoritative EventClassification derived from delta_seconds.
  classification String?
  /// cycle = nonce >> 32 (denormalized for range queries / joins).
  cycle          Int?
  /// slotIndex = nonce & 0xffffffff (denormalized).
  slotIndex      Int?
  /// pool.members_target at emit time (commitment context).
  groupSize      Int?
  /// installments paid in this event (1 for a contribution, 0 otherwise).
  parcelsPaid    Int?
  /// paid_ts - due_ts (seconds, i64). Negative = early, positive = late.
  deltaSeconds   BigInt?
  /// USDC base units moved by the event (0 for default / cycle-complete).
  amount         BigInt?
  /// On-chain `issued_at` (unix seconds).
  issuedAt       BigInt?
  /// On-chain `revoked` flag — revoked attestations are excluded from
  /// the off-chain score (C.3).
  revoked        Boolean  @default(false)

  /// Audit trail
  mintedAt    DateTime @default(now())
  /// Originating tx signature. NULLABLE since Phase C.2b — the
  /// account-scan backfill (getProgramAccounts) does not know which tx
  /// created the PDA; the webhook ingest path sets it when present.
  txSignature String?

  @@index([subject, schemaId])
  @@index([subject, classification])
  @@map("attestations")
}

// ─── Events (immutable log, one row per landed tx) ───────────────────

model ContributeEvent {
  id                String    @id @default(cuid())
  txSignature       String    @unique
  /// poolId/memberId are NULLABLE (ADR 0009 — fast-ingest, resolve-later).
  /// The ingest path resolves them when pool/member state is already in the
  /// DB (backfill), else writes NULL and the reconciler fills them. A hard
  /// FK + an "_unresolved" string sentinel were incompatible (every insert
  /// violated the FK); NULL is the FK-valid "not yet resolved" marker.
  pool              Pool?     @relation(fields: [poolId], references: [id])
  poolId            String?
  member            Member?   @relation(fields: [memberId], references: [id])
  memberId          String?
  /// Raw wallet pubkey from the on-chain log. **Nullable since
  /// Adevar Labs SEV-014 fix** — the program's actual `msg!` emission
  /// does NOT include the member wallet (only the slot_index, see
  /// `contribute.rs:226`). For new events, this stays null and the
  /// reconciler resolves the canonical memberId via `(poolId, slotIndex)`
  /// instead. Existing rows from pre-#321 still carry the wallet.
  contributorWallet String?
  /// Slot index from the on-chain log. Used by the reconciler to
  /// resolve canonical memberId via the `@@unique([poolId, slotIndex])`
  /// constraint on Member.
  ///
  /// **Note:** column was named `installment` in the pre-SEV-014
  /// schema (mistakenly — the program never emitted installment).
  /// Repurposed as the slot index. New event rows write slot_index
  /// here; pre-fix rows carry the old (incorrect) installment value.
  cycle             Int
  schemaId          Int
  /// **Note:** column kept for back-compat with pre-SEV-014 rows.
  /// New events write 0 — the program never emitted installment
  /// per-event (it's a Pool-level constant, not a contribute log
  /// field).
  installment       BigInt
  solidarityAmt     BigInt
  escrowAmt         BigInt
  /// **Renamed from `pool_float`** — program emits `pool=` (the
  /// portion routed to pool_usdc_vault after solidarity + escrow).
  /// Column name kept for backward compatibility with pre-SEV-014
  /// rows.
  poolFloatAmt      BigInt
  /// Slot index — Adevar SEV-014: program emits `slot=`, the
  /// reconciler uses this to resolve canonical Member via
  /// `(poolId, slotIndex)` instead of the previously-fictional
  /// `contributorWallet` field.
  slotIndex         Int       @default(0)
  onTime            Boolean
  blockTime         BigInt
  slot              BigInt
  /// Reconciler state (issue #234). `false` while unresolved or
  /// resolved-successfully; `true` when finality lookup failed
  /// past the orphan-grace window (tx dropped or reorged out).
  /// Orphaned rows are kept for audit trail but skipped by the
  /// B2B oracle's canonical-state reads.
  orphaned          Boolean   @default(false)
  /// Timestamp at which the reconciler resolved `poolId` + `memberId`
  /// to canonical IDs (NULL = still unresolved).
  resolvedAt        DateTime?

  @@index([poolId, cycle])
  @@index([orphaned, slot])
  @@map("contribute_events")
}

model ClaimEvent {
  id              String    @id @default(cuid())
  txSignature     String    @unique
  /// Nullable until resolved — see ContributeEvent (ADR 0009).
  pool            Pool?     @relation(fields: [poolId], references: [id])
  poolId          String?
  member          Member?   @relation(fields: [memberId], references: [id])
  memberId        String?
  /// Raw wallet pubkey of the payout recipient. **Nullable since
  /// Adevar Labs SEV-014 fix** — the program's `payout` msg (NOT
  /// `claim_payout`, which was a decoder fiction) does NOT include
  /// recipient. Reconciler resolves canonical memberId via
  /// (poolId, slotIndex) instead.
  recipientWallet String?
  cycle           Int
  slotIndex       Int
  amountPaid      BigInt
  blockTime       BigInt
  slot            BigInt
  orphaned        Boolean   @default(false)
  resolvedAt      DateTime?

  @@index([poolId, cycle])
  @@index([orphaned, slot])
  @@map("claim_events")
}

model DefaultEvent {
  id               String    @id @default(cuid())
  txSignature      String    @unique
  /// Nullable until resolved — see ContributeEvent (ADR 0009).
  pool             Pool?     @relation(fields: [poolId], references: [id])
  poolId           String?
  /// The defaulted member — denormalized as wallet because the Member
  /// row may have been closed by a subsequent escape_valve_buy.
  defaultedWallet  String
  cycle            Int
  slotIndex        Int
  /// Triple Shield seizure breakdown, all in USDC base units
  seizedSolidarity BigInt
  seizedEscrow     BigInt
  seizedStake      BigInt
  /// D/C invariant snapshot at seizure time
  dInit            BigInt
  dRem             BigInt
  cInit            BigInt
  cAfter           BigInt
  blockTime        BigInt
  slot             BigInt
  orphaned         Boolean   @default(false)
  resolvedAt       DateTime?

  @@index([poolId, slotIndex])
  @@index([orphaned, slot])
  @@map("default_events")
}

// ─── Indexer cursor state ────────────────────────────────────────────
//
// One row per (program_id, "transactions"). Tracks the last slot the
// backfill / live indexer processed so restarts pick up where they
// left off. Webhook handler updates this on every successful insert.

model IndexerCursor {
  id        String   @id @default(cuid())
  programId String   @unique
  lastSlot  BigInt
  lastSig   String?
  updatedAt DateTime @updatedAt

  @@map("indexer_cursors")
}

// Cron-health tracker for the getProgramAccounts backfill. One row per
// invocation — observability/README.md item #3 ("lastBackfillRunUnix +
// lastBackfillStatus pair") reads `findFirst(orderBy: startedAt desc)`
// at scrape time and emits the two gauges. Row-per-run history keeps
// the trail audit-traceable (when did backfills start failing?)
// without requiring a separate event store.
model BackfillRun {
  id             String    @id @default(cuid())
  programId      String
  status         String // "ok" | "error" | "running"
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  poolsTouched        Int       @default(0)
  membersTouched      Int       @default(0)
  attestationsTouched Int       @default(0)
  errorMessage        String?

  @@index([startedAt])
  @@index([programId, startedAt])
  @@map("backfill_runs")
}

// ─── Canonical normalized event store (ADR 0009) ──────────────────────
//
// The single normalized, exportable, backfill-rebuildable record the
// admin console queries. Per ADR 0009 we adopted the FALLBACK shape: the
// typed tables (contribute/claim/default) remain the ingestion +
// reconciliation surface (the load-bearing reconciler.ts truth-path is
// untouched), and THIS table is a deterministic PROJECTION of the
// already-reconciled typed rows. Because every column here is a pure
// function of (typed row + pool schedule), the table is rebuildable from
// zero (`projector.rebuildEvents`) and carries zero drift vs the typed
// rows — never write-once.
//
// Derived behavioral fields (dueTs / deltaSeconds / graceUsed) are
// computed via `@roundfi/sdk` `behavioral.ts` — the SAME definitions the
// app renders, mirroring the on-chain program (ADR 0009 §5). They are
// filled at projection time (post-resolution), because dueTs depends on
// `Pool.startedAt`, which is only known once the reconciler resolves the
// row's canonical pool.
//
// Only RESOLVED, non-orphaned typed rows are projected: orphaned rows are
// kept in the typed tables for audit but excluded from this canonical
// surface (ADR 0005 / 0009).
model Event {
  id                      String                   @id @default(cuid())
  /// Source tx signature. NOT unique alone — a claim both pays and
  /// advances the cycle in one tx, so a single signature can carry more
  /// than one event_type. Uniqueness is the (txSig, eventType) pair,
  /// which also keeps Helius redelivery idempotent (ADR 0009 amendment 3a).
  txSig                   String
  eventType               EventType
  /// Behavioral subject. contribute/claim: resolved Member.wallet;
  /// default: DefaultEvent.defaultedWallet (on the log directly).
  subjectWallet           String
  /// Canonical Pool.id + denormalized PDA (PDA lets the admin export /
  /// filter without a join).
  poolId                  String
  poolPda                 String
  /// Canonical Member.id when the source row resolved one (null for
  /// default rows — DefaultEvent has no Member FK in the schema).
  memberId                String?
  /// Cycle the tx acted on — taken from the on-chain log (so it is the
  /// cycle CURRENT at the tx's slot, not "now"; ADR 0009 backfill care #1).
  cycle                   Int
  slotIndex               Int
  /// Solana slot number of the source tx.
  slotNumber              BigInt
  /// On-chain block time (UNIX seconds) — the canonical `paid_at`.
  onChainTs               BigInt
  /// Cycle deadline = started_at + (cycle+1)*cycle_duration. NULL when
  /// the pool was not yet Active (started_at == 0). behavioral.dueTs.
  dueTs                   BigInt?
  /// onChainTs - dueTs. Only meaningful for `Contribute` (payment
  /// timing); NULL for claim/default (no payment timing).
  deltaSeconds            Int?
  /// Late-but-within-grace. Only set for `Contribute`. behavioral.usedGrace.
  graceUsed               Boolean                  @default(false)
  /// INFERRED by the indexer (the contract records no reason). Only set
  /// for `Default`. Always paired with `defaultReasonProvenance` so the
  /// admin never presents it as an on-chain fact (ADR 0009 amendment 3b).
  defaultReason           DefaultReason?
  defaultReasonProvenance DefaultReasonProvenance?
  /// Type-specific payload (payout credit/retained, seizure cascade
  /// breakdown, contribute split). Keeps the normalized columns lean
  /// while preserving every field for export/audit (ADR 0009).
  details                 Json
  /// Mirrors the source typed row's reconciliation state. orphaned rows
  /// are NOT projected; resolvedAt is copied from the typed row.
  resolvedAt              DateTime?
  /// When the projector last (re)wrote this row. Distinct from
  /// resolvedAt — proves rebuildability is observable.
  builtAt                 DateTime                 @default(now())

  @@unique([txSig, eventType])
  @@index([poolId, cycle])
  @@index([subjectWallet])
  @@index([eventType])
  @@index([slotNumber])
  @@map("events")
}

enum EventType {
  Contribute
  Claim
  Default
}

/// Inferred default cause (ADR 0009 amendment 3b). The contract emits no
/// reason — these are derived by the indexer and ALWAYS provenance-tagged.
enum DefaultReason {
  SolvencyGuardTriggered
  MissedDeadline
  InsufficientStake
  EscapeValveLeavingDefault
  Other
}

/// Provenance marker for `defaultReason`. Today the only value is
/// `Inferred`; the enum exists so a future on-chain reason field could
/// add `OnChain` without a column rename — and so the admin can render a
/// clear "inferred" badge.
enum DefaultReasonProvenance {
  Inferred
}

// ─── Admin shared store (RoundFi internal audit follow-up — Wave 2) ────────
//
// The admin SIWS single-use guard + auth rate limiter were originally
// in-memory (module-scope Set / Map). That is correct for a single
// instance but does NOT sync across instances behind a load balancer
// and does not survive process restart — the multi-instance gap flagged
// in the audit. These two tables back a Postgres-shared implementation
// selected by `ADMIN_SHARED_STORE=postgres`; the in-memory backend
// remains the default for the single-instance canary + CI (no DB).

// Single-use SIWS challenge guard. One row per CONSUMED challenge token.
// `verify` inserts the token on a successful sign-in; a duplicate insert
// (unique PK) IS the replay signal — atomic across instances, no
// read-modify-write race. Rows are retained until `expiresAt` (the
// challenge TTL) then swept opportunistically; a still-valid token can
// never be replayed because its row outlives its own validity window.
model AdminChallenge {
  /// The challengeToken HMAC (hex) — the natural single-use key.
  token      String   @id
  /// Subject pubkey, denormalized for audit ("who consumed this nonce").
  pubkey     String
  /// issuedAt + CHALLENGE_TTL_MS. After this the row is sweepable: the
  /// challenge is already TTL-rejected by `verifyChallengeShape`, so the
  /// single-use row no longer needs to exist.
  expiresAt  DateTime
  consumedAt DateTime @default(now())

  @@index([expiresAt])
  @@map("admin_challenges")
}

// Sliding-window rate-limit hit log. One row per accepted request,
// keyed by `<endpoint>:<client-ip>`. `check` deletes rows older than the
// window, counts the survivors, and inserts a new row when under the
// limit — the same sliding-window-log algorithm as the in-memory store,
// made durable + shared. Low-volume (auth endpoints only), so row-per-
// hit is cheap; the windowed DELETE keeps the table bounded.
model AdminRateLimitHit {
  id        String   @id @default(cuid())
  /// "<endpoint>:<client>" — e.g. "admin-auth-nonce:1.2.3.4".
  bucketKey String
  hitAt     DateTime @default(now())

  @@index([bucketKey, hitAt])
  @@map("admin_rate_limit_hits")
}

// ─── Reconciler leader election (Wave 9.2) ───────────────────────────────
//
// Single-row "lease" table that gates the reconciler daemon's periodic
// runs in a multi-instance deployment. The old `setInterval` design
// fired on EVERY replica simultaneously, racing on the same UPDATEs
// against the typed-event tables. The audit (Wave 9 survey) flagged
// this as a Med severity concurrency hazard.
//
// Lease semantics: each tick atomically attempts
//
//   UPDATE reconciler_leases
//      SET acquired_at = NOW(), holder = $1
//    WHERE id = 'main' AND acquired_at < NOW() - interval 'leaseTtlSecs'
//   RETURNING acquired_at;
//
// If the UPDATE returns a row, this instance won the lease and runs the
// tick. If it returns 0 rows, another instance is still inside its
// lease window — this tick skips with a structured info log. Failure-
// fail-safe: a crashed leader's lease expires after `leaseTtlSecs`
// and the next tick (on any replica) takes over.
//
// Single row with id="main" — bootstrapped by the migration. No GC
// needed: the row is recycled forever.
model ReconcilerLease {
  id         String   @id @default("main")
  acquiredAt DateTime @default(now())
  holder     String   @default("")

  @@map("reconciler_leases")
}

// ─── Export audit (ADR 0009) ──────────────────────────────────────────────
//
// The events export is the product asset + sensitive credit data, so every
// export is recorded: WHO (authenticated pubkey), WHEN, the filter applied,
// the format, and how many rows left. Append-only audit trail.
model ExportAudit {
  id        String   @id @default(cuid())
  /// Authenticated operator pubkey that performed the export.
  actor     String
  format    String // "csv" | "json"
  /// The exact filter object applied (for reproducibility / dispute).
  filter    Json
  rowCount  Int
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actor])
  @@map("export_audit")
}
