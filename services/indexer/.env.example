# services/indexer — env reference.
#
# The notifier (notify.ts / PR3b) is the main operator-run consumer here. It is
# DARK by default: nothing sends unless EMAIL_NOTIFICATIONS_ENABLED=true AND a
# real send backend (SMTP_HOST or RESEND_API_KEY) is configured.

# ─── Email notifier gate ──────────────────────────────────────────────────────
EMAIL_NOTIFICATIONS_ENABLED=true

# Shared opt-in DB — the SAME Postgres the app writes subscriptions to (a free
# Neon/Supabase instance works). Required for the full notifier; NOT needed for
# the NOTIFY_TEST_TO delivery test below.
DATABASE_URL=postgresql://user:pass@host:5432/roundfi

# Devnet RPC + program ids. Core is required for the full pass; reputation is
# optional (drives the "new group for your level" collateral framing).
SOLANA_RPC_URL=https://api.devnet.solana.com
ROUNDFI_CORE_PROGRAM_ID=8LVrgxKwKwqjcdq7rUUwWY2zPNk8anpo2JsaR9jTQQjw
ROUNDFI_REPUTATION_PROGRAM_ID=Hpo174C6JTCfiZ6r8VYVQdKxo3LBHaJmMbkgrEkxe9R2

# ─── SMTP send (Gmail — Option 1, zero cost, no domain) ───────────────────────
# Gmail: turn on 2-Step Verification, then create an "App Password" (16 chars).
# SMTP_PASS is that App Password — it is a SECRET: never commit it, never put it
# in a NEXT_PUBLIC_* var, never paste it in chat/PRs.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=roundfinance.sol@gmail.com
SMTP_PASS=your-16-char-app-password
# From defaults to SMTP_USER (Gmail rewrites the From to the authed address).
# SMTP_FROM=RoundFi <roundfinance.sol@gmail.com>
# SMTP_SECURE defaults from the port (465 = true / 587 = false).

# ─── Optional knobs ───────────────────────────────────────────────────────────
# NOTIFY_BASE_URL=https://roundfi.vercel.app           # absolute base for links
# NOTIFY_LOGO_URL=https://roundfi.vercel.app/...        # hosted brand image
# NOTIFY_DUE_WINDOW_HOURS=48                            # remind within N hours of due
# NOTIFY_INTERVAL_MS=300000                             # daemon cadence (5 min)
# NOTIFY_POOL_LABELS={"<poolPda>":"Pool Rápida"}        # friendly names per pool pda

# Quick delivery test — sends ONE sample of each template to this address and
# exits. No DATABASE_URL / no on-chain needed; proves the Gmail path end-to-end.
# NOTIFY_TEST_TO=you@email.com

# (Alternative send backend — Resend HTTP API; needs a verified domain.)
# RESEND_API_KEY=
# RESEND_FROM=RoundFi <alerts@yourdomain.app>
