# RoundFi app — environment template. Copy to `app/.env.local` (gitignored,
# auto-loaded by Next.js) and fill in. This committed `.env.example` is the
# reference so nobody has to reverse-engineer which vars the app needs.
#
# Minimum to run the app + reach the /admin/ops console locally:
#   the ADMIN_* block + the RPC/program-ids + DATABASE_URL.

# ─── Admin console auth (ADR 0009) — REQUIRED to access /admin/ops ──────────
# Session-signing secret. Fail-closed: admin auth refuses to run if this is
# unset or < 16 chars (every /api/admin/** returns 500 "server_misconfigured").
# GENERATE YOUR OWN — never commit a real one. A committed default secret =
# forgeable admin sessions for anyone who reads the repo. e.g.:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Comma-separated base58 pubkeys allowed into the console — PUBLIC keys only,
# never private keys. Put the wallet you click "connect" with at /admin. The
# on-chain ProtocolConfig.authority is ALSO allowed automatically when
# SOLANA_RPC_URL is set, so the devnet deployer works without listing it here.
ADMIN_ALLOWLIST=

# SIWS message domain. MUST match the host you browse from. Default is
# "admin.roundfi" (prod) — LOCAL LOGINS FAIL on domain mismatch unless you
# set this to localhost.
ADMIN_DOMAIN=localhost

# Optional rate-limit knobs (sane defaults if unset).
# ADMIN_RL_NONCE_PER_MIN=10
# ADMIN_RL_VERIFY_PER_MIN=5
# Optional shared rate-limit/session store (in-memory if unset).
# ADMIN_SHARED_STORE=

# ─── Email notifications opt-in (devnet-first, OFF by default) ──────────────
# Whole feature is dark unless this is exactly "true" — every
# /api/notifications/email* route 404s otherwise (keeps it out of mainnet
# builds unless explicitly enabled).
# EMAIL_NOTIFICATIONS_ENABLED=true
# Client-side twin: shows the opt-in card in /carteira → Conexões. Set this to
# "true" TOGETHER WITH EMAIL_NOTIFICATIONS_ENABLED (server) — the card is hidden
# unless this is set, and the endpoints 404 unless the server flag is set.
# NEXT_PUBLIC_EMAIL_NOTIFICATIONS_ENABLED=true
# HMAC secret binding the opt-in challenge. Fail-closed like ADMIN_SESSION_SECRET
# (>=16 chars) and DISTINCT from it so an admin challenge can't cross-replay as
# an email opt-in. GENERATE YOUR OWN: openssl rand -hex 32
# NOTIFY_SIGNING_SECRET=
# SIWS message domain for the opt-in signature (default "alerts.roundfi").
# NOTIFY_DOMAIN=alerts.roundfi
# Durable subscription store: "postgres" persists to the indexer DB (needs
# DATABASE_URL); in-memory if unset (lost on restart).
# EMAIL_SUBSCRIPTION_STORE=postgres
# Optional rate-limit knobs (sane defaults if unset).
# NOTIFY_RL_CHALLENGE_PER_MIN=10
# NOTIFY_RL_CONFIRM_PER_MIN=5

# ─── Indexer DB — admin/ops APIs read this (503 "indexer offline" if down) ──
# Start it:
#   docker run -d --name roundfi-pg -e POSTGRES_PASSWORD=roundfi -p 5432:5432 postgres:16
#   pnpm --filter @roundfi/indexer prisma:migrate
DATABASE_URL=postgresql://postgres:roundfi@localhost:5432/postgres

# ─── Server-side RPC + program ids (on-chain authority read, canary slot) ───
SOLANA_RPC_URL=https://api.devnet.solana.com
ROUNDFI_CORE_PROGRAM_ID=8LVrgxKwKwqjcdq7rUUwWY2zPNk8anpo2JsaR9jTQQjw
ROUNDFI_REPUTATION_PROGRAM_ID=Hpo174C6JTCfiZ6r8VYVQdKxo3LBHaJmMbkgrEkxe9R2

# ─── Client-side RPC (browser balance / pool reads) ─────────────────────────
# Public devnet rate-limits hard → 429 retry storm in the console. Point at a
# dedicated RPC to silence it (Helius / Triton free tier).
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_HELIUS_DEVNET=
# NEXT_PUBLIC_HELIUS_MAINNET=
# NEXT_PUBLIC_TRITON_DEVNET=
# NEXT_PUBLIC_TRITON_MAINNET=
