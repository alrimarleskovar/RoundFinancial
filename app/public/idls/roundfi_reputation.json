  "types": [
    {
      "name": "AttestArgs",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "schema_id",
            "type": "u16"
          },
          {
            "name": "nonce",
            "type": "u64"
          },
          {
            "name": "payload",
            "type": {
              "defined": {
                "name": "Payload"
              }
            }
          },
          {
            "name": "pool",
            "docs": [
              "Pool PDA key (used to derive `(subject, pool)` default-sticky",
              "check via the payload; caller must include it here so we can",
              "verify the issuer signer matches pool-PDA derivation)."
            ],
            "type": "pubkey"
          },
          {
            "name": "pool_authority",
            "docs": [
              "Pool authority (1st seed) + seed_id (2nd seed), needed to re-derive",
              "the pool PDA under `roundfi_core_program`."
            ],
            "type": "pubkey"
          },
          {
            "name": "pool_seed_id",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "Attestation",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "issuer",
            "type": "pubkey"
          },
          {
            "name": "subject",
            "type": "pubkey"
          },
          {
            "name": "schema_id",
            "type": "u16"
          },
          {
            "name": "nonce",
            "type": "u64"
          },
          {
            "name": "payload",
            "docs": [
              "Fixed 96-byte payload. Schema-specific layout; see",
              "architecture.md §4.6.3."
            ],
            "type": {
              "defined": {
                "name": "Payload"
              }
            }
          },
          {
            "name": "issued_at",
            "type": "i64"
          },
          {
            "name": "revoked",
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          },
          {
            "name": "verified_at_attest",
            "docs": [
              "Whether the subject had a verified `IdentityRecord` at the",
              "moment this attestation was issued. Snapshotted at attest time",
              "and immutable thereafter — `revoke` uses this stored value",
              "(not the CURRENT identity status) to determine the score",
              "reversal weight, ensuring `apply + revoke` is exactly",
              "zero-sum.",
              "",
              "Adevar Labs SEV-008 fix: without this snapshot, a subject who",
              "passed unverified→verified between attest and revoke would",
              "have their score over-reversed (apply with weight 1/2, revoke",
              "with weight 2/2 → score goes negative)."
            ],
            "type": "bool"
          },
          {
            "name": "_padding",
            "type": {
              "array": [
                "u8",
                13
              ]
            }
          }
        ]
      }
    },
    {
      "name": "IdentityGateConfig",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "docs": [
              "Authority allowed to change the gate. Set to `ReputationConfig.authority`",
              "at creation; `set_identity_gate` re-checks the live config authority on",
              "every call, so a later authority rotation is honored."
            ],
            "type": "pubkey"
          },
          {
            "name": "required_min_level",
            "docs": [
              "Lowest reputation level that requires a verified `IdentityRecord`.",
              "- `0` ≡ gate DISABLED (no level requires identity — the default).",
              "- `N` (2..=`LEVEL_MAX`) ≡ promotion to level ≥ N requires a verified",
              "identity; unverified subjects are capped at `N − 1`."
            ],
            "type": "u8"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "IdentityRecord",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "wallet",
            "type": "pubkey"
          },
          {
            "name": "provider",
            "docs": [
              "See `IdentityProvider` enum."
            ],
            "type": "u8"
          },
          {
            "name": "status",
            "docs": [
              "See `IdentityStatus` enum."
            ],
            "type": "u8"
          },
          {
            "name": "verified_at",
            "type": "i64"
          },
          {
            "name": "expires_at",
            "docs": [
              "0 ≡ never expires; else unix seconds of expiry."
            ],
            "type": "i64"
          },
          {
            "name": "gateway_token",
            "docs": [
              "Passport-attestation account address (when provider ==",
              "HumanPassport). Default pubkey for other providers. Field name",
              "kept as `gateway_token` for byte-compat with already-allocated",
              "IdentityRecord PDAs on devnet; semantic is now \"the off-chain",
              "bridge-service-written attestation account\" rather than the",
              "original Civic Gateway Token. See `identity/passport.rs`."
            ],
            "type": "pubkey"
          },
          {
            "name": "bump",
            "type": "u8"
          },
          {
            "name": "_padding",
            "type": {
              "array": [
                "u8",
                13
              ]
            }
          }
        ]
      }
    },
    {
      "name": "InitializeReputationArgs",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "roundfi_core_program",
            "type": "pubkey"
          },
          {
            "name": "passport_attestation_authority",
            "docs": [
              "Off-chain Human Passport bridge service pubkey. Field name",
              "matches `ReputationConfig.passport_attestation_authority`."
            ],
            "type": "pubkey"
          },
          {
            "name": "passport_network",
            "docs": [
              "Passport network scope. Field name matches",
              "`ReputationConfig.passport_network`."
            ],
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "Payload",
      "type": {
        "kind": "type",
        "alias": {
          "array": [
            "u8",
            96
          ]
        }
      }
    },
    {
      "name": "ProfileSnapshot",
      "docs": [
        "Canonical read snapshot. Order and field names are part of the",
        "public wire format — do not reorder; add new fields only by",
        "consuming bytes from `reserved`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "wallet",
            "type": "pubkey"
          },
          {
            "name": "level",
            "type": "u8"
          },
          {
            "name": "score",
            "type": "u64"
          },
          {
            "name": "cycles_completed",
            "type": "u32"
          },
          {
            "name": "on_time_payments",
            "type": "u32"
          },
          {
            "name": "late_payments",
            "type": "u32"
          },
          {
            "name": "defaults",
            "type": "u32"
          },
          {
            "name": "total_participated",
            "type": "u32"
          },
          {
            "name": "last_cycle_complete_at",
            "type": "i64"
          },
          {
            "name": "first_seen_at",
            "type": "i64"
          },
          {
            "name": "last_updated_at",
            "type": "i64"
          },
          {
            "name": "identity_provider",
            "type": "u8"
          },
          {
            "name": "identity_status",
            "type": "u8"
          },
          {
            "name": "identity_expires_at",
            "type": "i64"
          },
          {
            "name": "identity_verified_now",
            "type": "bool"
          },
          {
            "name": "reserved",
            "docs": [
              "Reserved for future schema additions without breaking",
              "consumers. Always zero in v1."
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          }
        ]
      }
    },
    {
      "name": "ProposeNewReputationAuthorityArgs",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "new_authority",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "ReputationConfig",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "docs": [
              "Admin authority — can update `passport_network` and whitelist issuers."
            ],
            "type": "pubkey"
          },
          {
            "name": "roundfi_core_program",
            "docs": [
              "The roundfi-core program ID whose `Pool` PDAs are trusted as",
              "attestation issuers. FROZEN after initialization."
            ],
            "type": "pubkey"
          },
          {
            "name": "passport_attestation_authority",
            "docs": [
              "**Passport attestation authority** — pubkey of the off-chain",
              "bridge service that translates Human Passport score queries",
              "into on-chain 83-byte attestation accounts. Validator requires",
              "`attestation_account.owner == passport_attestation_authority`.",
              "FROZEN at initialization. Field name kept generic so a future",
              "provider migration (e.g. → Sumsub for KYC-grade signal in",
              "Phase 3 B2B) is also byte-compatible."
            ],
            "type": "pubkey"
          },
          {
            "name": "passport_network",
            "docs": [
              "Passport \"network\" pubkey — a free-form scope identifier the",
              "bridge service embeds in every attestation it issues so",
              "rotation between e.g. \"passport-prod\" and \"passport-staging\"",
              "scopes is possible without re-deploying. Mutable so a",
              "mainnet migration can switch scope without a program upgrade."
            ],
            "type": "pubkey"
          },
          {
            "name": "paused",
            "docs": [
              "Emergency stop — short-circuits write-path instructions.",
              "**Adevar Labs SEV-022 carve-out:** pool-PDA-signed CPI from",
              "roundfi-core continues even when paused (so core's",
              "settle_default / contribute / claim_payout never lock-up via",
              "the back door of a paused reputation). See attest.rs handler."
            ],
            "type": "bool"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump."
            ],
            "type": "u8"
          },
          {
            "name": "pending_authority",
            "docs": [
              "Pending authority rotation. `Pubkey::default()` (all-zero) when",
              "no rotation queued. Set by `propose_new_reputation_authority`,",
              "cleared by `cancel_new_reputation_authority` or finalized by",
              "`commit_new_reputation_authority`. Mirrors the core program's",
              "authority rotation pattern (PR #323) — was originally a",
              "no-timelock rotation via `update_reputation_config`, which",
              "the auditor flagged as asymmetric with core's protection."
            ],
            "type": "pubkey"
          },
          {
            "name": "pending_authority_eta",
            "docs": [
              "Earliest unix-ts at which `commit_new_reputation_authority`",
              "may execute. `0` when no rotation pending. Equals",
              "`now + REPUTATION_AUTHORITY_TIMELOCK_SECS` (7d) at proposal",
              "time. Same window as core's authority + treasury rotations."
            ],
            "type": "i64"
          },
          {
            "name": "_padding",
            "docs": [
              "Reserved for future fields without a migration. Adevar SEV-021",
              "consumed 30 of the original 30 pad bytes (Pubkey 32 + i64 8 =",
              "40, exceeded pad by 10) — LEN grew by 10 to 170. Pre-PR",
              "devnet `ReputationConfig` accounts need re-init since Anchor",
              "sizes accounts at create time."
            ],
            "type": {
              "array": [
                "u8",
                0
              ]
            }
          }
        ]
      }
    },
    {
      "name": "ReputationProfile",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "wallet",
            "type": "pubkey"
          },
          {
            "name": "level",
            "docs": [
              "1..=3. Promoted permissionlessly via `promote_level`."
            ],
            "type": "u8"
          },
          {
            "name": "cycles_completed",
            "docs": [
              "Lifetime counters — additive-only for `cycles_completed` /",
              "`on_time_payments`, and non-negative for the *_count fields."
            ],
            "type": "u32"
          },
          {
            "name": "on_time_payments",
            "type": "u32"
          },
          {
            "name": "late_payments",
            "type": "u32"
          },
          {
            "name": "defaults",
            "type": "u32"
          },
          {
            "name": "total_participated",
            "docs": [
              "Unique pools this wallet has ever participated in. Incremented on",
              "the FIRST `CycleComplete` per (subject, pool). Duplicate-suppressed",
              "via the default-sticky bit and the cooldown guard."
            ],
            "type": "u32"
          },
          {
            "name": "score",
            "docs": [
              "Saturating non-negative score."
            ],
            "type": "u64"
          },
          {
            "name": "last_cycle_complete_at",
            "docs": [
              "Anti-gaming: timestamp of last `CycleComplete` attestation. Used",
              "to enforce `MIN_CYCLE_COOLDOWN_SECS` between two cycle closures",
              "for the same subject, even across pools."
            ],
            "type": "i64"
          },
          {
            "name": "first_seen_at",
            "docs": [
              "Bookkeeping."
            ],
            "type": "i64"
          },
          {
            "name": "last_updated_at",
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump."
            ],
            "type": "u8"
          },
          {
            "name": "last_admin_attest_at",
            "docs": [
              "**Adevar Labs SEV-027 fix** — anti-spam cooldown for admin-",
              "issued attestations. Updated on every attest where issuer ==",
              "config.authority (the admin path). Pool-PDA-issued attests",
              "have natural cooldown via the per-cycle structure of the",
              "core pool, so they do NOT bump this field.",
              "",
              "Used in attest.rs handler: admin-issued SCHEMA_PAYMENT requires",
              "`now - last_admin_attest_at >= MIN_ADMIN_ATTEST_COOLDOWN_SECS`.",
              "Without this, admin could pump score arbitrarily by issuing",
              "PAYMENT attestations in a tight loop."
            ],
            "type": "i64"
          },
          {
            "name": "_padding",
            "type": {
              "array": [
                "u8",
                7
              ]
            }
          }
        ]
      }
    },
    {
      "name": "UpdateReputationConfigArgs",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "new_authority",
            "docs": [
              "**DEPRECATED — ignored at the handler level (Adevar Labs SEV-021).**",
              "",
              "Was previously the only path to rotate `config.authority` —",
              "no timelock, no public window, single-tx irreversible attack",
              "if the key was compromised. Now the rotation flows through",
              "`propose_new_reputation_authority` → 7d wait →",
              "`commit_new_reputation_authority`, mirror of core's",
              "authority rotation (PR #323).",
              "",
              "The field is retained for SDK back-compat (old encoders pass",
              "`Option<Pubkey>` at this offset). The handler ignores any",
              "value passed here and emits a warning if non-None so a stale",
              "SDK is visible in monitoring."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "new_passport_network",
            "docs": [
              "Passport \"network\" scope rotation. Mutable so canary rampup can",
              "switch e.g. `passport-staging` → `passport-prod` without a",
              "program upgrade."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "new_paused",
            "type": {
              "option": "bool"
            }
          }
        ]
      }
    }
  ]
}