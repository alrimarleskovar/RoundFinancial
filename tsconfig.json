{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["node", "mocha", "chai"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/src/*"]
    }
  },
  "include": ["config/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"],
