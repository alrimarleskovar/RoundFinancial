{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    // Bankrun specs import from "./_harness/index.js". Resolving those .js
    // specifiers back to .ts sources requires a NodeNext-class resolver —
    // matches tsconfig.base.json and what `tsx` does at runtime.
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "mocha", "chai"],
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["./**/*.ts", "../sdk/src/**/*.ts", "../config/**/*.ts", "../app/src/lib/**/*.ts"],
  "exclude": ["../node_modules", "../target", "../dist", "**/generated/**"]
}
