# ─── Cluster ──────────────────────────────────────────────────────
SOLANA_CLUSTER=devnet                # localnet | devnet | mainnet-beta
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_API_KEY=

# ─── Program IDs (populated by scripts/devnet/deploy.ts) ──────────
ROUNDFI_CORE_PROGRAM_ID=
ROUNDFI_REPUTATION_PROGRAM_ID=
ROUNDFI_YIELD_MOCK_PROGRAM_ID=
ROUNDFI_YIELD_KAMINO_PROGRAM_ID=

# ─── Fixed constants (do not change) ──────────────────────────────
METAPLEX_CORE_PROGRAM_ID=CoREENxT6tW1HoK8ypY1SxRMZTcVPm7R94rH4PZNhX7d
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Wallets (paths, never secrets in .env) ───────────────────────
ANCHOR_WALLET=./keypairs/deployer.json
CRANK_KEYPAIR_PATH=./keypairs/crank.json
IRYS_FUNDER_KEYPAIR_PATH=./keypairs/irys.json

# ─── Arweave / Irys ───────────────────────────────────────────────
IRYS_NODE_URL=https://devnet.irys.xyz

# ─── Backend ──────────────────────────────────────────────────────
DATABASE_URL=postgres://roundfi:roundfi@localhost:5432/roundfi
REDIS_URL=redis://localhost:6379
# B2B_API_KEY_SALT: ≥32 random bytes hex-encoded for Phase 3 B2B oracle
# API-key derivation. MUST be set (empty rejects boot — see Adevar
# Labs SEV-010 — was previously a "change-me-before-prod" placeholder
# that could be copied as-is, weakening key derivation if missed).
# Generate via: openssl rand -hex 32
B2B_API_KEY_SALT=

# ─── Helius webhook (indexer auth, Adevar Labs SEV-009) ───────────
# Shared secret sent in Authorization header by Helius. Configure via
# Helius dashboard "Custom Headers" → "Authorization: Bearer <secret>".
# MUST be set for any non-local deploy. Generate via: openssl rand -hex 32
HELIUS_WEBHOOK_SECRET=

# ─── Crank intervals (seconds; see docs/devnet-setup.md) ──────────
CRANK_HARVEST_INTERVAL_SEC=21600     # 6h
CRANK_BONUS_INTERVAL_SEC=300         # poll every 5m
CRANK_DEFAULT_GRACE_SEC=604800       # 7d

# ─── Frontend (Next.js public env) ────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_CORE_PROGRAM_ID=
