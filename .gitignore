.env
.env.*
!.env.example
*.pem
*.key
id.json
wallet*.json

# IDE
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Claude Code session artifacts (per-developer, local only)
.claude/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python (scripts)
__pycache__/
*.pyc
.venv/
venv/

# Generated SDK (regenerated from IDL)
sdk/src/generated/

# Playwright E2E artifacts
app/test-results/
app/playwright-report/
app/blob-report/
app/playwright/.cache/

# cargo-fuzz growth corpus + crash artifacts. Only the per-target
# `canonical` seed file is committed (committed via `git ls-files`);
# everything else in corpus/ is libFuzzer-discovered noise that bloats
# the repo across re-runs. `artifacts/` holds crash inputs that
# should be triaged and added to corpus/ as canonical seeds before
# committing — never committed directly.
crates/math/fuzz/corpus/*/*
!crates/math/fuzz/corpus/*/canonical
crates/math/fuzz/artifacts/

# Ephemeral branch-cleanup inventories (generated locally, not for commit)
.cleanup-branches-*.txt
